{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Nggedhekaké Gambar",
  "version": "0.1.0",
  "identifier": "com.bangadamdev.nggedhekake-gambar",
  "build": {
    "beforeDevCommand": "$HOME/.cargo/bin/dx serve --port 1420 --interactive false",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "$HOME/.cargo/bin/dx bundle --release --debug-symbols false",
    "frontendDist": "../dist/public"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Nggedhekaké Gambar",
        "width": 1200,
        "height": 760,
        "minWidth": 920,
        "minHeight": 620
      }
    ],
    "security": {
      "csp": "default-src 'self' ipc: http://ipc.localhost; img-src 'self' asset: http://asset.localhost data: blob:; style-src 'self' 'unsafe-inline'",
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "binaries/",
      "models/"
    ]
  }
}

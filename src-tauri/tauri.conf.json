{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Nggedhekaké Gambar",
  "version": "0.1.0",
  "identifier": "com.bangadamdev.nggedhekake-gambar",
  "build": {
    "beforeDevCommand": "dx serve --port 1420 --interactive false",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "dx bundle --release --debug-symbols false",
    "frontendDist": "../dist/public"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Nggedhekaké Gambar",
        "width": 1200,
        "height": 760,
        "minWidth": 920,
        "minHeight": 620
      }
    ],
    "security": {
      "csp": "default-src 'self' ipc: http://ipc.localhost; script-src 'self' 'wasm-unsafe-eval'; img-src 'self' asset: http://asset.localhost data: blob:; style-src 'self' 'unsafe-inline'",
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "category": "Utility",
    "shortDescription": "A private, native image upscaler powered by Real-ESRGAN, NCNN, and Vulkan",
    "longDescription": "Upscale one PNG, JPEG, or WebP image at a time locally on macOS without uploading it.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "binaries/upscayl-bin": "binaries/upscayl-bin",
      "binaries/realesrgan-ncnn-vulkan": "binaries/realesrgan-ncnn-vulkan",
      "models/": "models/",
      "../LICENSE": "licenses/Nggedhekake-Gambar-AGPL-3.0.txt",
      "binaries/REAL_ESRGAN_NCNN_VULKAN_LICENSE": "licenses/REAL_ESRGAN_NCNN_VULKAN_LICENSE"
    }
  }
}

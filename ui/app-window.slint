import { Button } from "std-widgets.slint";

export component AppWindow inherits Window {
    title: "Nggedhekaké Gambar";
    width: 1120px;
    height: 720px;
    background: #f7f6f3;

    in-out property <image> preview-image;
    in-out property <bool> has-source: false;
    in-out property <bool> has-error: false;
    in-out property <string> source-name: "";
    in-out property <string> source-path: "";
    in-out property <string> source-details: "";
    in-out property <string> error-message: "";
    in-out property <string> status-text: "Choose an image to begin";

    callback choose-image();

    VerticalLayout {
        padding: 24px;
        spacing: 16px;

        HorizontalLayout {
            height: 42px;

            Text {
                width: 360px;
                horizontal-stretch: 0;
                text: "Nggedhekaké Gambar";
                color: #171717;
                font-size: 28px;
                font-weight: 700;
                vertical-alignment: center;
            }

            Rectangle { horizontal-stretch: 1; }

            HorizontalLayout {
                width: 72px;
                horizontal-stretch: 0;
                spacing: 8px;
                alignment: center;

                Rectangle {
                    width: 10px;
                    height: 10px;
                    border-radius: 5px;
                    background: root.has-source ? #346538 : #908c86;
                }

                Text {
                    width: 46px;
                    text: root.has-source ? "Ready" : "Idle";
                    color: #6d6a64;
                    font-size: 13px;
                    vertical-alignment: center;
                }
            }
        }

        HorizontalLayout {
            spacing: 16px;
            vertical-stretch: 1;

            Rectangle {
                width: 320px;
                background: #f1f0ec;
                border-color: #e3e0d9;
                border-width: 1px;
                border-radius: 10px;

                VerticalLayout {
                    padding: 24px;
                    spacing: 16px;

                    Text {
                        text: "Source image";
                        color: #171717;
                        font-size: 18px;
                        font-weight: 700;
                    }

                    Text {
                        text: "Drop one PNG, JPEG, or WebP anywhere in this window.";
                        color: #6d6a64;
                        font-size: 14px;
                        wrap: word-wrap;
                    }

                    Rectangle {
                        height: 174px;
                        background: #ffffff;
                        border-color: root.has-error ? #9f2f2d : #d3d0c8;
                        border-width: 1px;
                        border-radius: 8px;

                        VerticalLayout {
                            padding: 20px;
                            spacing: 12px;
                            alignment: center;

                            Text {
                                text: root.has-source ? "Image selected" : "Drop image here";
                                color: #171717;
                                font-size: 15px;
                                font-weight: 600;
                                horizontal-alignment: center;
                            }

                            Text {
                                text: root.has-source ? "Choose another file at any time" : "or use the native file picker";
                                color: #6d6a64;
                                font-size: 13px;
                                horizontal-alignment: center;
                                wrap: word-wrap;
                            }

                            Button {
                                text: root.has-source || root.has-error ? "Choose another image" : "Choose image";
                                clicked => { root.choose-image(); }
                            }
                        }
                    }

                    if root.has-source: Rectangle {
                        background: #ffffff;
                        border-color: #e3e0d9;
                        border-width: 1px;
                        border-radius: 8px;
                        height: 112px;

                        VerticalLayout {
                            padding: 12px;
                            spacing: 5px;

                            Text {
                                text: root.source-name;
                                color: #171717;
                                font-size: 14px;
                                font-weight: 600;
                                overflow: elide;
                            }

                            Text {
                                text: root.source-details;
                                color: #6d6a64;
                                font-size: 12px;
                            }

                            Text {
                                text: root.source-path;
                                color: #6d6a64;
                                font-family: "monospace";
                                font-size: 12px;
                                overflow: elide;
                            }
                        }
                    }

                    if root.has-error: Rectangle {
                        background: #fdebec;
                        border-color: #e9c7c8;
                        border-width: 1px;
                        border-radius: 8px;

                        Text {
                            x: 12px;
                            y: 10px;
                            width: parent.width - 24px;
                            height: parent.height - 20px;
                            text: root.error-message;
                            color: #7f2423;
                            font-size: 13px;
                            wrap: word-wrap;
                            vertical-alignment: center;
                        }
                    }

                    Rectangle { vertical-stretch: 1; }

                    Text {
                        text: "Images stay on this device.";
                        color: #6d6a64;
                        font-size: 12px;
                    }
                }
            }

            Rectangle {
                background: #ffffff;
                border-color: #e3e0d9;
                border-width: 1px;
                border-radius: 10px;
                horizontal-stretch: 1;

                if root.has-source: Image {
                    x: 20px;
                    y: 20px;
                    width: parent.width - 40px;
                    height: parent.height - 40px;
                    source: root.preview-image;
                    image-fit: contain;
                }

                if !root.has-source: VerticalLayout {
                    x: 48px;
                    y: 48px;
                    width: parent.width - 96px;
                    height: parent.height - 96px;
                    alignment: center;
                    spacing: 10px;

                    Text {
                        text: "Preview";
                        color: #171717;
                        font-size: 18px;
                        font-weight: 600;
                        horizontal-alignment: center;
                    }

                    Text {
                        text: "Your selected image will appear here.";
                        color: #6d6a64;
                        font-size: 14px;
                        horizontal-alignment: center;
                    }
                }
            }
        }

        Rectangle {
            height: 40px;
            background: #f1f0ec;
            border-radius: 8px;

            HorizontalLayout {
                padding-left: 12px;
                padding-right: 12px;
                alignment: center;

                Text {
                    text: root.status-text;
                    color: root.has-error ? #7f2423 : #4f4c47;
                    font-size: 13px;
                    vertical-alignment: center;
                }
            }
        }
    }
}
